# Hızlı kurulum — yerel `npm run dev` (Postgres host port 5442 / ML 5042 ile uyumlu).
# Docker Compose api konteynerinde bu dosyayı ezmez.

DATABASE_URL=postgres://rota:rota123@127.0.0.1:5442/rota
ML_SERVICE_URL=http://127.0.0.1:5042
ML_ENABLED=true
ML_TIMEOUT_MS=15000
# ML kapalı/hata: true=rastgele yedek doluluk, false=0 yolcu (sadece gerçek ML)
ML_USE_MOCK_ON_FAILURE=true
ML_DEFAULT_RESMITATIL=0
PORT=3142
NODE_ENV=development
PUBLIC_API_URL=https://gorisle.dalciksoft.com
TRUST_PROXY=0
